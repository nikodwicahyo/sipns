FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY=generate-a-long-random-secret-key-here
DATABASE_URL=mysql+pymysql://user:password@localhost:3306/sipns_prod?charset=utf8mb4
DATABASE_URL_TEST=mysql+pymysql://root:@localhost:3306/sipns_test?charset=utf8mb4

# Format: mysql+pymysql://username:password@host:port/database

# Connection pool (optional, has sensible defaults)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=3600
# DB_CONNECT_TIMEOUT=10
